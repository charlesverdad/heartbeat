# Ghost CMS Configuration
# Copy this to .env and fill in your values

# Your Ghost blog URL (no trailing slash)
GHOST_API_URL=https://heartbeatchurch.com.au

# Ghost Admin API Key
# Get this from Ghost Admin > Settings > Integrations > Add custom integration
GHOST_ADMIN_API_KEY=your_admin_api_key_here

# Ghost API Version (usually v5.0 for recent Ghost versions)
GHOST_API_VERSION=v5.0
